---
import Layout from '../layouts/Layout.astro'

const termosUrl = `${import.meta.env.BASE_URL}termos-de-uso`
---

<Layout title="Enviar Projeto">

  <!-- HERO -->
  <section class="bg-green-800 text-white text-center" style="padding: 48px 24px;">
    <h1 class="text-3xl font-bold">Cadastrar Novo Projeto</h1>
    <p class="mt-2 text-green-200">Compartilhe seu projeto maker com a comunidade UDESC. Preencha as informações abaixo.</p>
  </section>

  <div style="max-width: 900px; margin: 0 auto; padding: 40px 48px;">

    <!-- STEPPER -->
    <div class="flex items-center justify-center gap-2 mb-10">
      {[
        { n: 1, label: 'Informações Básicas' },
        { n: 2, label: 'Detalhes do Projeto' },
        { n: 3, label: 'Passo a Passo' },
        { n: 4, label: 'Revisão e Envio' },
      ].map((step, i) => (
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium step-item" data-step={step.n}>
            <span class="step-circle w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold" style="min-width:24px">
              {step.n}
            </span>
            <span class="step-label">{step.label}</span>
          </div>
          {i < 3 && <div class="w-8 h-px bg-gray-300"></div>}
        </div>
      ))}
    </div>

    <!-- ETAPA 1 -->
    <div id="etapa-1" class="etapa">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Informações Básicas</h2>
      <div class="space-y-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título do Projeto <span class="text-red-500">*</span></label>
          <input id="titulo" type="text" placeholder="Ex: Robô de segurança"
            data-sequential-required required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Frase de Contexto <span class="text-red-500">*</span></label>
          <p class="text-xs text-gray-400 mb-1">Uma frase que resume a ideia do projeto</p>
          <input id="resumo" type="text" placeholder="Ex: Construa seu Robô de forma simples e rápida"
            data-sequential-required required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Imagem de Capa</label>
          <div class="flex gap-2 items-center">
            <input id="capa-url" type="text" placeholder="Cole uma URL ou envie um arquivo"
              class="flex-1 border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50" />
            <label class="flex items-center gap-2 bg-green-700 hover:bg-green-800 text-white px-4 py-3 rounded-lg text-sm font-medium transition-colors cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
              </svg>
              Enviar arquivo
              <input id="capa-file" type="file" accept="image/*" class="hidden" />
            </label>
          </div>
          <div id="capa-preview" class="mt-2 hidden">
            <img id="capa-img" src="" alt="Preview da capa" class="h-32 rounded-lg object-cover border border-gray-200" />
            <p id="capa-nome" class="text-xs text-gray-500 mt-1"></p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Seu Nome <span class="text-red-500">*</span></label>
            <input id="autor" type="text" placeholder="Nome completo"
              data-sequential-required required
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Seu e-mail <span class="text-red-500">*</span></label>
            <input id="email" type="email" placeholder="seu@email.com"
              data-sequential-required required
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tags</label>
          <p class="text-xs text-gray-400 mb-1">Pressione Enter ou vírgula para adicionar (máx. 10)</p>
          <div class="flex gap-2">
            <input id="tag-input" type="text" placeholder="Ex: arduino"
              class="flex-1 border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50" />
            <button id="btn-add-tag" class="w-10 h-10 mt-1 border border-gray-300 rounded-lg flex items-center justify-center hover:border-green-500 transition-colors text-gray-500 text-xl">+</button>
          </div>
          <div id="tags-container" class="flex flex-wrap gap-2 mt-2"></div>
        </div>

      </div>
    </div>

    <!-- ETAPA 2 -->
    <div id="etapa-2" class="etapa hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Detalhes do Projeto</h2>
      <div class="space-y-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descrição do Projeto <span class="text-red-500">*</span></label>
          <p class="text-xs text-gray-400 mb-2">Descreva o que é o projeto, seu objetivo e o que será aprendido. Use os botões para aplicar formatação em Markdown.</p>
          <div class="border border-gray-200 rounded-xl bg-white p-3" data-markdown-editor-root>
            <div class="flex flex-wrap gap-2 mb-3" data-markdown-toolbar></div>
            <textarea id="descricao" rows="6" placeholder="Descreva seu projeto em detalhes..."
              data-sequential-required required
              class="markdown-editor-textarea w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 resize-none disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200"></textarea>
            <div class="mt-3 rounded-lg border border-gray-200 bg-gray-50 p-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-gray-400 mb-2">Prévia da formatação</p>
              <div class="markdown-preview-content min-h-16 text-sm text-gray-600" data-markdown-preview></div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Categoria <span class="text-red-500">*</span></label>
            <select id="categoria" data-sequential-required required class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200">
              <option value="">Selecione...</option>
              <option>Eletrônica</option><option>Robótica</option><option>Impressão 3D</option>
              <option>Programação</option><option>Marcenaria</option><option>Costura</option>
              <option>Culinária</option><option>Arte</option><option>Outros</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Idade Mínima</label>
            <select id="idade" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50">
              <option value="">Selecione...</option>
              <option>+5 Anos</option><option>+10 Anos</option><option>+15 Anos</option>
              <option>+18 Anos</option><option>Todos os públicos</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Dificuldade <span class="text-red-500">*</span></label>
            <select id="dificuldade" data-sequential-required required class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200">
              <option value="">Selecione...</option>
              <option>Iniciante</option><option>Intermediário</option><option>Avançado</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Duração Estimada <span class="text-red-500">*</span></label>
            <select id="duracao" data-sequential-required required class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none bg-gray-50 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed disabled:border-gray-200">
              <option value="">Selecione...</option>
              <option>-30 Minutos</option><option>-1hora</option><option>1-3 horas</option>
              <option>Meio dia</option><option>1 dia</option><option>+1 dia</option>
            </select>
          </div>
        </div>

      </div>
    </div>

    <!-- ETAPA 3 -->
    <div id="etapa-3" class="etapa hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Passo a Passo</h2>
      <div id="passos-container" class="space-y-4"></div>
      <button id="btn-add-passo"
        class="w-full mt-4 border-2 border-dashed border-gray-300 hover:border-green-500 text-gray-500 hover:text-green-600 py-4 rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2">
        <span class="text-xl">+</span> Adicionar novo passo
      </button>
    </div>

    <!-- ETAPA 4 -->
    <div id="etapa-4" class="etapa hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Revisão e Envio</h2>

      <div id="preview-card" class="border border-gray-200 rounded-xl p-6 mb-6 bg-white"></div>

      <div class="border border-gray-200 rounded-xl p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Termos de Uso</h3>
          <a href={termosUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-green-600 hover:underline">Ler termos completos</a>
        </div>
        <label class="flex items-start gap-3 cursor-pointer">
          <input id="aceite-termos" type="checkbox" data-sequential-required required class="mt-0.5 w-4 h-4 flex-shrink-0 disabled:opacity-50 disabled:cursor-not-allowed" />
          <span class="text-sm text-gray-600">
            Li e aceito os <a href={termosUrl} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()" class="text-green-600 font-medium hover:underline">Termos de Uso</a> da plataforma UDESC Maker e declaro que o conteúdo enviado está em conformidade com as diretrizes. <span class="text-red-500">*</span>
          </span>
        </label>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <button id="btn-baixar-zip"
          class="flex items-center justify-center gap-2 border-2 border-green-600 text-green-700 hover:bg-green-50 py-4 rounded-xl font-semibold text-sm transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Baixar arquivos (.zip)
        </button>
        <button id="btn-enviar-github"
          class="flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-semibold text-sm transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Enviar via GitHub (PR automático)
        </button>
      </div>

      <div id="status-envio" class="hidden mt-4 p-4 rounded-lg text-sm"></div>
    </div>

    <!-- NAVEGAÇÃO -->
    <div class="flex justify-between mt-10 pt-6 border-t border-gray-100">
      <button id="btn-anterior"
        class="flex items-center gap-2 border border-gray-300 text-gray-600 px-6 py-3 rounded-lg font-medium hover:border-gray-400 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Anterior
      </button>
      <button id="btn-proximo"
        class="flex items-center gap-2 bg-green-800 hover:bg-green-900 text-white px-6 py-3 rounded-lg font-medium transition-colors disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:bg-green-800">
        Próximo
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

  </div>

</Layout>

<script>
  import JSZip from 'jszip'

  // ── ESTADO ────────────────────────────────────────────
  let etapaAtual = 1
  const totalEtapas = 4
  let tags: string[] = []
  let passos: {
    titulo: string
    descricao: string
    arquivo: File | null
    url: string
    anexo: File | null
    anexoNome: string
  }[] = []
  let capaFile: File | null = null

  // ── HELPERS ───────────────────────────────────────────
  function escaparHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  function val(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
    return el?.value?.trim() || ''
  }

  function slugify(str: string): string {
    return str.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '')
  }

  function mostrarStatus(msg: string, tipo: 'sucesso' | 'erro' | 'carregando') {
    const el = document.getElementById('status-envio')!
    el.classList.remove('hidden')
    const cores = {
      sucesso: 'background:#dcfce7; color:#166534;',
      erro: 'background:#fee2e2; color:#991b1b;',
      carregando: 'background:#fef9c3; color:#854d0e;',
    }
    el.setAttribute('style', cores[tipo])
    el.textContent = msg
  }

  type CampoObrigatorioSequencial = HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement

  function camposObrigatoriosSequenciais(): CampoObrigatorioSequencial[] {
    return Array.from(document.querySelectorAll('[data-sequential-required]')) as CampoObrigatorioSequencial[]
  }

  function campoSequencialPreenchido(campo: CampoObrigatorioSequencial): boolean {
    if (campo instanceof HTMLInputElement && campo.type === 'checkbox') return campo.checked
    return campo.value.trim() !== ''
  }

  function atualizarEstadoBotaoProximo() {
    const btnProximo = document.getElementById('btn-proximo') as HTMLButtonElement | null
    if (!btnProximo || etapaAtual === totalEtapas) return

    const camposDaEtapa = Array.from(
      document.querySelectorAll(`#etapa-${etapaAtual} [data-sequential-required]`)
    ) as CampoObrigatorioSequencial[]

    btnProximo.disabled = !camposDaEtapa.every(campoSequencialPreenchido)
  }

  function atualizarCamposObrigatoriosSequenciais() {
    const campos = camposObrigatoriosSequenciais()

    campos.forEach((campo, index) => {
      const bloqueado = index > 0 && !campoSequencialPreenchido(campos[index - 1])
      campo.disabled = bloqueado
      campo.setAttribute('aria-disabled', bloqueado ? 'true' : 'false')
    })

    atualizarEstadoBotaoProximo()
    atualizarEstadoToolbarsMarkdown()
  }

  function registrarEventosCamposObrigatorios() {
    camposObrigatoriosSequenciais().forEach(campo => {
      campo.addEventListener('input', atualizarCamposObrigatoriosSequenciais)
      campo.addEventListener('change', atualizarCamposObrigatoriosSequenciais)
    })
  }

  // ── EDITOR MARKDOWN ───────────────────────────────────
  const botoesMarkdown = [
    { acao: 'bold', rotulo: 'B', titulo: 'Negrito' },
    { acao: 'italic', rotulo: 'I', titulo: 'Itálico' },
    { acao: 'heading', rotulo: 'H3', titulo: 'Subtítulo' },
    { acao: 'list', rotulo: '• Lista', titulo: 'Lista com marcadores' },
    { acao: 'ordered-list', rotulo: '1. Lista', titulo: 'Lista numerada' },
    { acao: 'table', rotulo: 'Tabela', titulo: 'Inserir tabela' },
    { acao: 'link', rotulo: 'Link', titulo: 'Inserir link' },
    { acao: 'code', rotulo: '{ }', titulo: 'Código' },
  ] as const

  function obterToolbarMarkdownHtml(): string {
    return botoesMarkdown.map(botao => `
      <button type="button"
        class="markdown-toolbar-button px-3 py-2 rounded-lg border border-gray-200 bg-gray-50 hover:border-green-500 hover:text-green-700 text-xs font-semibold text-gray-600 transition-colors"
        data-md-action="${botao.acao}"
        title="${botao.titulo}"
        aria-label="${botao.titulo}">
        ${botao.rotulo}
      </button>
    `).join('')
  }

  function aplicarPrefixoNasLinhas(texto: string, prefixo: (index: number) => string): string {
    return texto
      .split('\n')
      .map((linha, index) => `${prefixo(index)}${linha || 'Item'}`)
      .join('\n')
  }

  function atualizarValorTextarea(
    textarea: HTMLTextAreaElement,
    valor: string,
    selecaoInicio: number,
    selecaoFim: number,
  ) {
    textarea.value = valor
    textarea.focus()
    textarea.setSelectionRange(selecaoInicio, selecaoFim)
    textarea.dispatchEvent(new Event('input', { bubbles: true }))
  }

  function aplicarFormatacaoMarkdown(textarea: HTMLTextAreaElement, acao: string) {
    if (textarea.disabled) return

    const inicio = textarea.selectionStart ?? 0
    const fim = textarea.selectionEnd ?? 0
    const antes = textarea.value.slice(0, inicio)
    const selecionado = textarea.value.slice(inicio, fim)
    const depois = textarea.value.slice(fim)
    const quebraAntes = inicio > 0 && !antes.endsWith('\n') ? '\n' : ''

    let insercao = ''
    let selecaoInicio = inicio
    let selecaoFim = fim

    if (acao === 'bold') {
      const conteudo = selecionado || 'texto em negrito'
      insercao = `**${conteudo}**`
      selecaoInicio = inicio + 2
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'italic') {
      const conteudo = selecionado || 'texto em itálico'
      insercao = `*${conteudo}*`
      selecaoInicio = inicio + 1
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'heading') {
      const conteudo = selecionado || 'Título da seção'
      insercao = `${quebraAntes}### ${conteudo}`
      selecaoInicio = inicio + quebraAntes.length + 4
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'list') {
      const conteudo = selecionado
        ? aplicarPrefixoNasLinhas(selecionado, () => '- ')
        : '- Primeiro item\n- Segundo item'
      insercao = `${quebraAntes}${conteudo}`
      selecaoInicio = inicio + quebraAntes.length
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'ordered-list') {
      const conteudo = selecionado
        ? aplicarPrefixoNasLinhas(selecionado, (index) => `${index + 1}. `)
        : '1. Primeiro item\n2. Segundo item'
      insercao = `${quebraAntes}${conteudo}`
      selecaoInicio = inicio + quebraAntes.length
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'table') {
      const conteudo = [
        '| Coluna 1 | Coluna 2 |',
        '| --- | --- |',
        '| Valor 1 | Valor 2 |',
      ].join('\n')
      insercao = `${quebraAntes}${conteudo}`
      selecaoInicio = inicio + quebraAntes.length + 2
      selecaoFim = selecaoInicio + 'Coluna 1'.length
    } else if (acao === 'link') {
      const conteudo = selecionado || 'texto do link'
      const url = 'https://example.com'
      insercao = `[${conteudo}](${url})`
      selecaoInicio = inicio + 1
      selecaoFim = selecaoInicio + conteudo.length
    } else if (acao === 'code') {
      const conteudo = selecionado || 'codigo'
      insercao = selecionado.includes('\n')
        ? `${quebraAntes}\`\`\`\n${conteudo}\n\`\`\``
        : `\`${conteudo}\``
      const deslocamento = selecionado.includes('\n') ? quebraAntes.length + 4 : 1
      selecaoInicio = inicio + deslocamento
      selecaoFim = selecaoInicio + conteudo.length
    } else {
      return
    }

    atualizarValorTextarea(
      textarea,
      `${antes}${insercao}${depois}`,
      selecaoInicio,
      selecaoFim,
    )
  }

  function markdownInlineParaHtml(texto: string): string {
    let html = escaparHtml(texto)
    const placeholdersCodigo: string[] = []

    html = html.replace(/`([^`]+)`/g, (_, codigo: string) => {
      const token = `__CODE_${placeholdersCodigo.length}__`
      placeholdersCodigo.push(`<code style="background:#e5e7eb; color:#111827; padding:2px 6px; border-radius:6px; font-size:0.85em;">${codigo}</code>`)
      return token
    })

    html = html.replace(/\[([^\]]+)\]\(((?:https?:\/\/|mailto:)[^)]+)\)/g, (_, label: string, url: string) => {
      return `<a href="${escaparHtml(url)}" target="_blank" rel="noopener noreferrer" style="color:#15803d; text-decoration:underline;">${label}</a>`
    })

    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong style="font-weight:700; color:#111827;">$1</strong>')
    html = html.replace(/\*([^*]+)\*/g, '<em style="font-style:italic;">$1</em>')

    placeholdersCodigo.forEach((codigo, index) => {
      html = html.replace(`__CODE_${index}__`, codigo)
    })

    return html
  }

  function markdownParaHtml(markdown: string): string {
    if (!markdown.trim()) {
      return '<p style="margin:0; color:#9ca3af;">A prévia da formatação aparece aqui.</p>'
    }

    const linhas = markdown.split(/\r?\n/)
    const partes: string[] = []
    const paragrafoAtual: string[] = []
    let listaNaoOrdenadaAberta = false
    let listaOrdenadaAberta = false
    let blocoCodigoAberto = false
    let linhasCodigo: string[] = []
    let pularAte = -1

    function extrairCelulasTabela(linha: string): string[] {
      return linha
        .trim()
        .replace(/^\|/, '')
        .replace(/\|$/, '')
        .split('|')
        .map(celula => celula.trim())
    }

    function ehSeparadorTabela(linha: string): boolean {
      const celulas = extrairCelulasTabela(linha)
      return celulas.length > 0 && celulas.every(celula => /^:?-{3,}:?$/.test(celula))
    }

    function estiloAlinhamentoTabela(celula: string): string {
      const conteudo = celula.trim()
      if (conteudo.startsWith(':') && conteudo.endsWith(':')) return 'center'
      if (conteudo.endsWith(':')) return 'right'
      return 'left'
    }

    function fecharParagrafo() {
      if (!paragrafoAtual.length) return
      partes.push(`
        <p style="margin:0 0 12px 0; color:#374151; line-height:1.7;">
          ${paragrafoAtual.map(markdownInlineParaHtml).join('<br />')}
        </p>
      `)
      paragrafoAtual.length = 0
    }

    function fecharListas() {
      if (listaNaoOrdenadaAberta) {
        partes.push('</ul>')
        listaNaoOrdenadaAberta = false
      }
      if (listaOrdenadaAberta) {
        partes.push('</ol>')
        listaOrdenadaAberta = false
      }
    }

    function fecharBlocoCodigo() {
      if (!blocoCodigoAberto) return
      partes.push(`
        <pre style="margin:0 0 12px 0; padding:12px; border-radius:12px; background:#111827; color:#f9fafb; overflow:auto; font-size:0.85rem;"><code>${escaparHtml(linhasCodigo.join('\n'))}</code></pre>
      `)
      blocoCodigoAberto = false
      linhasCodigo = []
    }

    linhas.forEach((linhaBruta, index) => {
      if (index <= pularAte) return

      const linha = linhaBruta.trim()

      if (linha.startsWith('```')) {
        fecharParagrafo()
        fecharListas()
        if (blocoCodigoAberto) {
          fecharBlocoCodigo()
        } else {
          blocoCodigoAberto = true
          linhasCodigo = []
        }
        return
      }

      if (blocoCodigoAberto) {
        linhasCodigo.push(linhaBruta)
        return
      }

      if (!linha) {
        fecharParagrafo()
        fecharListas()
        return
      }

      const proximaLinha = linhas[index + 1]?.trim() || ''
      if (linha.includes('|') && ehSeparadorTabela(proximaLinha)) {
        fecharParagrafo()
        fecharListas()

        const cabecalhos = extrairCelulasTabela(linha)
        const alinhamentos = extrairCelulasTabela(proximaLinha).map(estiloAlinhamentoTabela)
        const linhasTabela: string[][] = []
        let ultimoIndiceTabela = index + 1

        for (let i = index + 2; i < linhas.length; i++) {
          const linhaTabela = linhas[i].trim()
          if (!linhaTabela || !linhaTabela.includes('|')) break
          linhasTabela.push(extrairCelulasTabela(linhaTabela))
          ultimoIndiceTabela = i
        }

        const colunas = cabecalhos.length
        const cabecalhoHtml = cabecalhos.map((cabecalho, colunaIndex) => `
          <th style="padding:10px 12px; border:1px solid #d1d5db; background:#f3f4f6; text-align:${alinhamentos[colunaIndex] || 'left'}; font-weight:700; color:#111827;">
            ${markdownInlineParaHtml(cabecalho)}
          </th>
        `).join('')
        const corpoHtml = linhasTabela.map((linhaAtual) => {
          const celulas = Array.from({ length: colunas }, (_, colunaIndex) => linhaAtual[colunaIndex] || '')
          return `
            <tr>
              ${celulas.map((celula, colunaIndex) => `
                <td style="padding:10px 12px; border:1px solid #d1d5db; text-align:${alinhamentos[colunaIndex] || 'left'}; color:#374151;">
                  ${markdownInlineParaHtml(celula)}
                </td>
              `).join('')}
            </tr>
          `
        }).join('')

        partes.push(`
          <div style="margin:0 0 12px 0; overflow-x:auto;">
            <table style="width:100%; border-collapse:collapse; min-width:320px;">
              <thead><tr>${cabecalhoHtml}</tr></thead>
              <tbody>${corpoHtml}</tbody>
            </table>
          </div>
        `)

        pularAte = ultimoIndiceTabela
        return
      }

      if (/^###\s+/.test(linha)) {
        fecharParagrafo()
        fecharListas()
        partes.push(`<h4 style="margin:0 0 12px 0; font-size:1rem; font-weight:700; color:#111827;">${markdownInlineParaHtml(linha.replace(/^###\s+/, ''))}</h4>`)
        return
      }

      if (/^##\s+/.test(linha)) {
        fecharParagrafo()
        fecharListas()
        partes.push(`<h3 style="margin:0 0 12px 0; font-size:1.1rem; font-weight:700; color:#111827;">${markdownInlineParaHtml(linha.replace(/^##\s+/, ''))}</h3>`)
        return
      }

      if (/^#\s+/.test(linha)) {
        fecharParagrafo()
        fecharListas()
        partes.push(`<h2 style="margin:0 0 12px 0; font-size:1.2rem; font-weight:700; color:#111827;">${markdownInlineParaHtml(linha.replace(/^#\s+/, ''))}</h2>`)
        return
      }

      if (/^>\s+/.test(linha)) {
        fecharParagrafo()
        fecharListas()
        partes.push(`<blockquote style="margin:0 0 12px 0; padding-left:12px; border-left:3px solid #86efac; color:#4b5563;">${markdownInlineParaHtml(linha.replace(/^>\s+/, ''))}</blockquote>`)
        return
      }

      if (/^\d+\.\s+/.test(linha)) {
        fecharParagrafo()
        if (listaNaoOrdenadaAberta) {
          partes.push('</ul>')
          listaNaoOrdenadaAberta = false
        }
        if (!listaOrdenadaAberta) {
          partes.push('<ol style="margin:0 0 12px 20px; color:#374151;">')
          listaOrdenadaAberta = true
        }
        partes.push(`<li style="margin-bottom:6px;">${markdownInlineParaHtml(linha.replace(/^\d+\.\s+/, ''))}</li>`)
        return
      }

      if (/^[-*]\s+/.test(linha)) {
        fecharParagrafo()
        if (listaOrdenadaAberta) {
          partes.push('</ol>')
          listaOrdenadaAberta = false
        }
        if (!listaNaoOrdenadaAberta) {
          partes.push('<ul style="margin:0 0 12px 20px; color:#374151; list-style:disc;">')
          listaNaoOrdenadaAberta = true
        }
        partes.push(`<li style="margin-bottom:6px;">${markdownInlineParaHtml(linha.replace(/^[-*]\s+/, ''))}</li>`)
        return
      }

      paragrafoAtual.push(linha)
    })

    fecharParagrafo()
    fecharListas()
    fecharBlocoCodigo()

    return partes.join('')
  }

  function preencherToolbarsMarkdown(container: ParentNode = document) {
    container.querySelectorAll('[data-markdown-toolbar]').forEach((toolbar) => {
      if ((toolbar as HTMLElement).childElementCount > 0) return
      ;(toolbar as HTMLElement).innerHTML = obterToolbarMarkdownHtml()
    })
  }

  function atualizarEstadoToolbarsMarkdown(container: ParentNode = document) {
    container.querySelectorAll('[data-markdown-editor-root]').forEach((root) => {
      const textarea = root.querySelector('.markdown-editor-textarea') as HTMLTextAreaElement | null
      if (!textarea) return
      root.querySelectorAll('[data-md-action]').forEach((botao) => {
        const el = botao as HTMLButtonElement
        el.disabled = textarea.disabled
        el.classList.toggle('opacity-50', textarea.disabled)
        el.classList.toggle('cursor-not-allowed', textarea.disabled)
      })
    })
  }

  function atualizarPreviewMarkdown(textarea: HTMLTextAreaElement) {
    const root = textarea.closest('[data-markdown-editor-root]')
    const preview = root?.querySelector('[data-markdown-preview]') as HTMLElement | null
    if (!preview) return
    preview.innerHTML = markdownParaHtml(textarea.value)
  }

  function atualizarPreviewsMarkdown(container: ParentNode = document) {
    preencherToolbarsMarkdown(container)
    container.querySelectorAll('.markdown-editor-textarea').forEach((textarea) => {
      atualizarPreviewMarkdown(textarea as HTMLTextAreaElement)
    })
    atualizarEstadoToolbarsMarkdown(container)
  }

  // ── STEPPER ───────────────────────────────────────────
  function atualizarStepper() {
    document.querySelectorAll('.step-item').forEach(el => {
      const n = parseInt((el as HTMLElement).dataset.step || '0')
      const circle = el.querySelector('.step-circle') as HTMLElement
      if (n < etapaAtual) {
        el.setAttribute('style', 'background:#054B28; color:white; padding:8px 16px; border-radius:999px;')
        circle.textContent = '✓'
      } else if (n === etapaAtual) {
        el.setAttribute('style', 'background:#139954; color:white; padding:8px 16px; border-radius:999px;')
        circle.textContent = String(n)
      } else {
        el.setAttribute('style', 'background:white; color:#6b7280; border:1px solid #d1d5db; padding:8px 16px; border-radius:999px;')
        circle.textContent = String(n)
      }
    })
  }

  // ── NAVEGAÇÃO ─────────────────────────────────────────
  function mostrarEtapa(n: number) {
    document.querySelectorAll('.etapa').forEach(el => el.classList.add('hidden'))
    document.getElementById(`etapa-${n}`)?.classList.remove('hidden')

    const btnAnterior = document.getElementById('btn-anterior') as HTMLElement
    const btnProximo = document.getElementById('btn-proximo') as HTMLElement

    btnAnterior.style.visibility = n === 1 ? 'hidden' : 'visible'
    btnProximo.style.display = n === totalEtapas ? 'none' : 'flex'

    if (n === 3 && passos.length === 0) adicionarPasso()
    if (n === 4) renderizarPreview()

    atualizarStepper()
    atualizarCamposObrigatoriosSequenciais()
  }

  document.getElementById('btn-proximo')?.addEventListener('click', () => {
    if (etapaAtual === 3) salvarPassosDoDOM()
    if (etapaAtual < totalEtapas) { etapaAtual++; mostrarEtapa(etapaAtual) }
  })

  document.getElementById('btn-anterior')?.addEventListener('click', () => {
    if (etapaAtual === 3) salvarPassosDoDOM()
    if (etapaAtual > 1) { etapaAtual--; mostrarEtapa(etapaAtual) }
  })

  // ── CAPA ──────────────────────────────────────────────
  document.getElementById('capa-file')?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0]
    if (!file) return
    capaFile = file
    const reader = new FileReader()
    reader.onload = (ev) => {
      const preview = document.getElementById('capa-preview')!
      const img = document.getElementById('capa-img') as HTMLImageElement
      const nome = document.getElementById('capa-nome')!
      img.src = ev.target?.result as string
      nome.textContent = file.name
      preview.classList.remove('hidden')
      ;(document.getElementById('capa-url') as HTMLInputElement).value = file.name
    }
    reader.readAsDataURL(file)
  })

  // ── TAGS ──────────────────────────────────────────────
  function adicionarTag(valor: string) {
    const tag = valor.trim().replace(/,/g, '').toLowerCase()
    if (!tag || tags.length >= 10 || tags.includes(tag)) return
    tags.push(tag)
    renderizarTags()
  }

  function renderizarTags() {
    const container = document.getElementById('tags-container')!
    container.innerHTML = tags.map(t => `
      <span class="flex items-center gap-1 text-xs px-3 py-1 rounded-full" style="background:#dcfce7; color:#166534;">
        #${t}
        <button data-tag="${t}" class="btn-remove-tag ml-1 font-bold hover:text-red-500">×</button>
      </span>
    `).join('')
    container.querySelectorAll('.btn-remove-tag').forEach(btn => {
      btn.addEventListener('click', () => {
        tags = tags.filter(t => t !== (btn as HTMLElement).dataset.tag)
        renderizarTags()
      })
    })
  }

  document.getElementById('btn-add-tag')?.addEventListener('click', () => {
    const input = document.getElementById('tag-input') as HTMLInputElement
    adicionarTag(input.value); input.value = ''
  })

  document.getElementById('tag-input')?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ',') {
      e.preventDefault()
      const input = e.target as HTMLInputElement
      adicionarTag(input.value); input.value = ''
    }
  })

  // ── PASSOS ────────────────────────────────────────────
  function salvarPassosDoDOM() {
    document.querySelectorAll('.passo-item').forEach((el, i) => {
      const fileInput = el.querySelector('.passo-file') as HTMLInputElement
      const anexoInput = el.querySelector('.passo-anexo-file') as HTMLInputElement
      passos[i] = {
        titulo: (el.querySelector('.passo-titulo') as HTMLInputElement)?.value || '',
        descricao: (el.querySelector('.passo-descricao') as HTMLTextAreaElement)?.value || '',
        url: (el.querySelector('.passo-url') as HTMLInputElement)?.value || '',
        arquivo: fileInput?.files?.[0] || passos[i]?.arquivo || null,
        anexo: anexoInput?.files?.[0] || passos[i]?.anexo || null,
        anexoNome: passos[i]?.anexoNome || '',
      }
    })
  }

  function adicionarPasso() {
    salvarPassosDoDOM()
    passos.push({ titulo: '', descricao: '', arquivo: null, url: '', anexo: null, anexoNome: '' })
    renderizarPassos()
  }

