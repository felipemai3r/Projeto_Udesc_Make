---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
    return [
        { params: { slug: "horta-inteligente" } },
        { params: { slug: "robo-seguidor" } },
        { params: { slug: "caixinha-musica" } },
    ];
}

const { slug } = Astro.params;

const projeto = {
    slug: "horta-inteligente",
    titulo: "Horta Inteligente com Sensor de Umidade",
    resumo: "Monte uma horta automatizada que monitora a umidade do solo e rega automaticamente suas plantas usando Arduino e sensores.",
    descricao:
        "Este projeto é ideal para quem quer aprender na prática os conceitos de eletrônica de forma acessível e divertida. Todos os materiais são facilmente encontrados em lojas de eletrônica ou online.",
    autor: "Felipe Silva",
    data: "01-11-2025",
    duracao: "1 dia",
    nivel: "Avançado",
    idade: "+18 Anos",
    categoria: "Eletrônica",
    tags: ["Arduino", "plantação"],
    materiais: [
        "Arduino Uno R3",
        "Sensores infravermelhos (x2)",
        "Driver motor L298N",
        "Motores DC (x2)",
        "Chassi de acrílico",
        "Rodas (x2) + rodabolos",
        "Jumpers e protoboard",
        "Bateria 9v",
    ],
    passos: [
        {
            titulo: "Montar o chassi",
            descricao:
                "Fixe os motores DC no chassi de acrílico usando parafusos. Instale as rodas e a rodabolsa na parte traseira.",
        },
        {
            titulo: "Conectar o driver de motor",
            descricao:
                "Ligue o driver L298N aos motores DC e conecte a alimentação da bateria 9V.",
        },
        {
            titulo: "Instalar os sensores",
            descricao:
                "Posicione os sensores infravermelhos na parte frontal do robô, apontados para o chão.",
        },
        {
            titulo: "Programar o Arduino",
            descricao:
                "Carregue o código que lê os sensores e controla os motores para seguir a linha preta.",
        },
        {
            titulo: "Testar e calibrar",
            descricao:
                "Coloque o robô sobre uma pista com fita isolante preta e ajuste a sensibilidade dos sensores.",
        },
    ],
    resultadoFinal:
        "Ao final deste projeto, você terá uma horta inteligente com sensor de umidade totalmente funcional, pronto para demonstrações e apresentações na comunidade maker da UDESC.",
};

const nivelCor: Record<string, string> = {
    Iniciante: "text-green-600",
    Intermediário: "text-yellow-600",
    Avançado: "text-red-500",
};
---

<Layout title={projeto.titulo}>
    <!-- HERO -->
    <section
        class="relative min-h-[200px] bg-green-800 overflow-hidden flex items-end"
    >
        <!-- se tiver imagem de capa, ela entra aqui como background -->
        <div
            class="absolute inset-0 bg-gradient-to-t from-green-900/90 to-green-800/60"
        >
        </div>
        <div class="relative z-10 w-full max-w-4xl mx-auto px-8 py-8">
            <div class="flex items-center gap-3">
                <div
                    class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0"
                >
                    <svg
                        class="w-5 h-5 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                        ></path>
                    </svg>
                </div>
                <h1 class="text-white text-2xl font-bold leading-snug">
                    {projeto.titulo}
                </h1>
            </div>
        </div>
    </section>

    <!-- CONTEÚDO -->
    <div class="max-w-7xl mx-auto px-8 py-8">
        <!-- BREADCRUMB -->
        <nav class="text-sm text-gray-400 mb-6">
            <a href="/" class="hover:text-green-700 transition-colors">Home</a>
            <span class="mx-2">›</span>
            <a href="/" class="hover:text-green-700 transition-colors"
                >Projetos</a
            >
            <span class="mx-2">›</span>
            <span class="text-gray-600">{projeto.titulo}</span>
        </nav>

        <!-- METADADOS + BOTÕES -->
        <div
            class="flex flex-wrap items-start justify-between gap-4 mb-8 pb-6 border-b border-gray-100"
        >
            <div
                class="flex flex-wrap items-center gap-3 text-sm text-gray-500"
            >
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                    {projeto.autor}
                </span>
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                        ></path>
                    </svg>
                    {projeto.data}
                </span>
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                    {projeto.duracao}
                </span>
                <span class={`font-semibold ${nivelCor[projeto.nivel]}`}>
                    Nível: {projeto.nivel}
                </span>
                <span
                    class="px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600"
                >
                    {projeto.idade}
                </span>
            </div>

            <div class="flex gap-2 flex-shrink-0 mt-2 mb-2">
                <button
                    class="flex items-center gap-2 border border-green-600 text-green-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-50 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                        ></path>
                    </svg>
                    Compartilhar
                </button>
                <button
                    class="flex items-center gap-2 border border-green-600 text-green-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-50 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                        ></path>
                    </svg>
                    Baixar Manual
                </button>
            </div>
        </div>

        <!-- SOBRE O PROJETO -->
        <section class="mb-10">
            <h2 class="text-lg font-bold text-gray-900  mt-4 mb-3">
                Sobre o Projeto
            </h2>
            <p class="text-gray-600 leading-relaxed">{projeto.resumo}</p>
            <p class="text-gray-600 leading-relaxed mt-2">
                {projeto.descricao}
            </p>
        </section>

        <!-- MATERIAIS -->
        <section class="mb-10">
            <h2 class="text-lg font-bold text-gray-900 mt-4 mb-4">
                Materiais Necessários
            </h2>
            <ul class="space-y-3">
                {
                    projeto.materiais.map((m) => (
                        <li class="flex items-center gap-3 text-gray-600 text-sm">
                            <input
                                type="checkbox"
                                class="accent-green-600 w-4 h-4 flex-shrink-0"
                            />
                            {m}
                        </li>
                    ))
                }
            </ul>
        </section>

        <!-- PASSO A PASSO -->
        <section class="mb-10">
        <h2 class="text-lg font-bold text-gray-900 mt-4 mb-6">Passo a Passo</h2>
        <div class="space-y-10">
            {projeto.passos.map((passo, i) => (
            <div class="flex gap-6">
                
                <!-- Coluna do número -->
                <div class="flex flex-col items-center gap-2 flex-shrink-0">
                <span style="width: 20px; height: 30px; min-width: 30px;" class="rounded-full bg-green-600 text-white text-sm font-bold flex items-center justify-center">
                    {i + 1}
                </span>
                <!-- linha vertical conectando os passos -->
                {i < projeto.passos.length - 1 && (
                    <div class="w-px flex-1 bg-green-100 min-h-[60px]"></div>
                )}
                </div>

                <!-- Coluna do conteúdo -->
                <div class="flex-1 pb-2">
                <h3 class="font-semibold text-green-700 mb-2">{passo.titulo}</h3>
                <p class="text-gray-600 text-sm mb-4">{passo.descricao}</p>
                <div class="bg-gray-100 rounded-xl h-44 flex items-center justify-center text-gray-400 text-xs">
                    [ imagem do passo ]
                </div>
                </div>

            </div>
            ))}
        </div>
        </section>

        <!-- RESULTADO FINAL -->
        <section class="mb-10">
            <h2 class="text-lg font-bold text-gray-900 mt-4 mb-3">
                Resultado Final
            </h2>
            <div
                class="bg-gray-100 rounded-xl h-52 flex items-center justify-center text-gray-400 text-xs mb-4"
            >
                [ imagem resultado final ]
            </div>
            <p class="text-gray-600 text-sm">{projeto.resultadoFinal}</p>
        </section>

        <!-- TAGS -->
        <div class="flex gap-3 flex-wrap pb-4">
            {
                projeto.tags.map((tag) => (
                    <span class="text-green-700 text-sm font-medium">
                        #{tag}
                    </span>
                ))
            }
        </div>
    </div>

    <!-- CTA FINAL -->
    <section class="bg-green-800 py-16 text-center text-white">
        <h2 class="text-3xl font-bold">Tem um projeto para compartilhar?</h2>
        <p class="mt-2 text-green-200">
            Contribua com a comunidade maker da UDESC
        </p>
        <a
            href="/contribuir"
            class="mt-6 inline-block bg-white text-green-800 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors"
        >
            Enviar via GitHub
        </a>
    </section>
</Layout>
