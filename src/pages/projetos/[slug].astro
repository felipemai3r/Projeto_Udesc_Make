---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
    const projetos = await getCollection("projetos");
    return projetos.map((entry) => ({
        params: {
            slug: entry.id.replace("/index.md", "").replace("\\index.md", ""),
        },
        props: { entryId: entry.id },
    }));
}

const { entryId } = Astro.props;
const projeto = await getEntry("projetos", entryId);

if (!projeto) return Astro.redirect("/404");

const { Content } = await render(projeto);

const { title, autor, data, categoria, dificuldade, duracao, idade, capa, tags } = projeto.data;

const nivelCor: Record<string, string> = {
    Iniciante: "text-green-600",
    Intermediário: "text-yellow-600",
    Avançado: "text-red-500",
};

---

<script>
  const button = document.getElementById("compartilhar");

  button?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
    } catch (error) {
      console.error(error);
    }
  });
</script>

<Layout title={title}>
    <!-- HERO -->
    <section
        class="relative min-h-[200px] bg-green-800 overflow-hidden flex items-end"
    >
        {capa && (
            <img
                src={capa ? `${import.meta.env.BASE_URL}${capa.replace(/^\//, '')}` : ''}
                alt={title}
                class="absolute inset-0 w-full h-full object-cover opacity-40"
            />
        )}
        <div
            class="absolute inset-0 bg-gradient-to-t from-green-900/90 to-green-800/60"
        >
        </div>
        <div class="relative z-10 w-full max-w-4xl mx-auto px-8 py-8">
            <div class="flex items-center gap-3">
                <div
                    class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center flex-shrink-0"
                >
                    <svg
                        class="w-5 h-5 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                        ></path>
                    </svg>
                </div>
                <h1 class="text-white text-2xl font-bold leading-snug">
                    {title}
                </h1>
            </div>
        </div>
    </section>

    <!-- CONTEÚDO -->
    <div class="max-w-7xl mx-auto px-8 py-8">
        <!-- BREADCRUMB -->
        <nav class="text-sm text-gray-400 mb-6">
            <a href={import.meta.env.BASE_URL} class="hover:text-green-700 transition-colors">Home</a>
            <span class="mx-2">›</span>
            <a href={`${import.meta.env.BASE_URL}#projetos`} class="hover:text-green-700 transition-colors">Projetos</a>
            <span class="mx-2">›</span>
            <span class="text-gray-600">{title}</span>
        </nav>

        <!-- METADADOS + BOTÕES -->
        <div
            class="flex flex-wrap items-start justify-between gap-4 mb-8 pb-6 border-b border-gray-100"
        >
            <div
                class="flex flex-wrap items-center gap-3 text-sm text-gray-500"
            >
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                    {autor}
                </span>
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                        ></path>
                    </svg>
                    {data}
                </span>
                <span class="flex items-center gap-1">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                    {duracao}
                </span>
                <span class={`font-semibold ${nivelCor[dificuldade] ?? "text-gray-500"}`}>
                    Nível: {dificuldade}
                </span>
                {idade && (
                    <span class="px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600">
                        {idade}
                    </span>
                )}
                <span class="px-2 py-0.5 rounded-full text-xs bg-green-100 text-green-700">
                    {categoria}
                </span>
            </div>

            <div class="flex gap-2 flex-shrink-0 mt-2 mb-2">
                <button
                id="compartilhar"
                    class="flex items-center gap-2 border border-green-600 text-green-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-50 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                        ></path>
                    </svg>
                    Compartilhar
                </button>
            </div>
        </div>

        <!-- CONTEÚDO DO MARKDOWN -->
        <article class="prose prose-green max-w-none mb-10
            prose-headings:text-gray-900
            prose-h2:text-lg prose-h2:font-bold prose-h2:mt-8 prose-h2:mb-3
            prose-h3:text-base prose-h3:font-semibold prose-h3:text-green-700 prose-h3:mb-2
            prose-p:text-gray-600 prose-p:leading-relaxed prose-p:text-sm
            prose-li:text-gray-600 prose-li:text-sm
            prose-ul:space-y-2
        ">
            <Content />
        </article>

        <!-- TAGS -->
        <div class="flex gap-3 flex-wrap pb-4 border-t border-gray-100 pt-4">
            {
                tags.map((tag) => (
                    <span class="text-green-700 text-sm font-medium">
                        #{tag}
                    </span>
                ))
            }
        </div>
    </div>

    <!-- CTA FINAL -->
    <section class="bg-green-800 py-16 text-center text-white">
        <h2 class="text-3xl font-bold">Tem um projeto para compartilhar?</h2>
        <p class="mt-2 text-green-200">
            Contribua com a comunidade maker da UDESC
        </p>
        <a
            href={`${import.meta.env.BASE_URL}contribuir`}
            class="mt-6 inline-block bg-white text-green-800 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors"
        >
            Enviar via GitHub
        </a>
    </section>
</Layout>
