---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const projetos = await getCollection('projetos')

const projetosFormatados = projetos.map(p => ({
  slug: p.id.replace('/index.md', '').replace('\\index.md', ''),
  titulo: p.data.title,
  resumo: p.data.resumo,
  categoria: p.data.categoria,
  nivel: p.data.dificuldade,
  duracao: p.data.duracao,
  idade: p.data.idade || 'Todos',
  autor: p.data.autor,
  capa: p.data.capa || '',
  tags: p.data.tags,
}))

const baseUrl = import.meta.env.BASE_URL
---

<Layout title="Início">

  <!-- HERO -->
<section>
  <div class="relative overflow-hidden min-h-[420px] md:min-h-[500px] shadow-xl bg-gray-900">

    <!-- Vídeo A -->
    <video
      id="hero-video-a"
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-80 transition-opacity duration-[2000ms] ease-in-out scale-105"
    >
      <source src={`${import.meta.env.BASE_URL}videos/video1.mp4`} type="video/mp4" />
    </video>

    <!-- Vídeo B -->
    <video
      id="hero-video-b"
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-[2000ms] ease-in-out scale-105"
    >
      <source src={`${import.meta.env.BASE_URL}videos/video2.mp4`} type="video/mp4" />
    </video>

    <!-- Camada de suavização -->
    <div class="absolute inset-0 backdrop-blur-[3px]"></div>

    <!-- Camada escura -->
    <div class="absolute inset-0 bg-white/55"></div>

    <!-- Gradiente para dar profundidade -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/45 to-black/25"></div>

    <!-- Conteúdo -->
    <div class="relative z-10 flex items-center min-h-[420px] md:min-h-[500px] px-[60px] py-12">
      <div class="max-w-2xl">
        <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight">
          Explore. Crie.<br/>
          <span class="text-green-400">Compartilhe.</span>
        </h1>

        <p class="mt-4 text-gray-100 text-lg md:text-xl">
          A plataforma de projetos maker da UDESC e da comunidade, onde aprender acontece na prática.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="#projetos"
            class="bg-green-700 hover:bg-green-800 text-white px-6 py-3 rounded-lg font-medium transition-colors"
          >
            Explore Projetos
          </a>

          <a
            href={`${import.meta.env.BASE_URL}contribuir`}
            class="border border-white/40 hover:border-white text-white px-6 py-3 rounded-lg font-medium transition-colors bg-white/10 hover:bg-white/15"
          >
            Como Contribuir
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

  <!-- BUSCA E FILTROS -->
  <section id="projetos" class="max-w-6xl mx-auto px-8 mt-12">

    <!-- Barra de busca -->
    <div class="flex gap-3 mb-4">
      <div class="flex-1 flex items-center gap-2 border border-gray-200 rounded-lg px-4 py-3 bg-white">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="busca"
          type="text"
          placeholder="Buscar Projetos"
          class="flex-1 outline-none text-gray-700 placeholder-gray-400"
        />
      </div>
      <button
        id="btn-filtros"
        class="bg-green-700 hover:bg-green-800 text-white px-5 py-3 rounded-lg font-medium transition-colors">
        Filtros
      </button>
    </div>

    <!-- Chips de categoria -->
    <div class="flex flex-wrap gap-2 mb-4" id="chips-categoria">
      {['Todos', 'Eletrônica', 'Robótica', 'Impressão 3D', 'Programação', 'Marcenaria', 'Costura', 'Culinária', 'Arte', 'Outros'].map((cat) => (
        <button
          class="chip-categoria px-4 py-1.5 rounded-full text-sm font-medium border transition-colors"
          data-categoria={cat}>
          {cat}
        </button>
      ))}
    </div>

    <!-- Filtros expandidos -->
    <div id="filtros-expandidos" class="hidden bg-white border border-gray-200 rounded-xl p-5 mb-6 space-y-4">

      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-semibold text-gray-700 w-28">Nível</span>
        <div class="flex flex-wrap gap-2" id="chips-nivel">
          {['Todos', 'Iniciante', 'Intermediário', 'Avançado'].map(n => (
            <button class="chip-nivel px-3 py-1 rounded-full text-sm border transition-colors" data-nivel={n}>{n}</button>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-semibold text-gray-700 w-28">Duração</span>
        <div class="flex flex-wrap gap-2" id="chips-duracao">
          {['Todos', '-30 Minutos', '-1hora', '1-3 horas', 'Meio dia', '1 dia', '+1 dia'].map(d => (
            <button class="chip-duracao px-3 py-1 rounded-full text-sm border transition-colors" data-duracao={d}>{d}</button>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-semibold text-gray-700 w-28">Idade Mínima</span>
        <div class="flex flex-wrap gap-2" id="chips-idade">
          {['Todos', '+5 Anos', '+10 Anos', '+15 Anos', '+18 Anos'].map(i => (
            <button class="chip-idade px-3 py-1 rounded-full text-sm border transition-colors" data-idade={i}>{i}</button>
          ))}
        </div>
      </div>

    </div>

    <!-- Contagem + por página -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-sm text-gray-500" id="contagem">0 Projetos encontrados</p>
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <span>Por página:</span>
        <div class="flex gap-1" id="chips-por-pagina">
          {[3, 6, 12, 24, 48].map(n => (
            <button
              class="chip-por-pagina px-3 py-1 rounded-full border text-sm transition-colors"
              data-n={n}>
              {n}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Grid de cards -->
    <div id="grid-projetos" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    </div>

    <!-- PAGINAÇÃO -->
    <div id="paginacao" class="flex items-center justify-center gap-1 mb-16 hidden">
      <button id="btn-anterior-pag"
        class="w-9 h-9 rounded-lg border border-gray-200 flex items-center justify-center text-gray-500 hover:border-green-600 hover:text-green-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <div id="numeros-pagina" class="flex gap-1"></div>
      <button id="btn-proximo-pag"
        class="w-9 h-9 rounded-lg border border-gray-200 flex items-center justify-center text-gray-500 hover:border-green-600 hover:text-green-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

  </section>

  <!-- CTA FINAL -->
  <section class="bg-green-800 mt-4 py-16 text-center text-white">
    <h2 class="text-3xl font-bold">Tem um projeto para compartilhar?</h2>
    <p class="mt-2 text-green-200">Contribua com a comunidade maker da UDESC</p>
    <a href={`${import.meta.env.BASE_URL}contribuir`} class="mt-6 inline-block bg-white text-green-800 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors">
      Enviar via GitHub
    </a>
  </section>

</Layout>

<script define:vars={{ projetosFormatados, baseUrl }}>
  const projetos = projetosFormatados

  // ── ESTADO ────────────────────────────────────────────
  let filtros = { categoria: 'Todos', nivel: 'Todos', duracao: 'Todos', idade: 'Todos', busca: '' }
  let paginaAtual = 1
  let porPagina = 6

  // ── CARD ──────────────────────────────────────────────
  const coresNivel = {
    'Iniciante': 'color:#16a34a',
    'Intermediário': 'color:#d97706',
    'Avançado': 'color:#ef4444',
  }

  function criarCard(p) {
    const corNivel = coresNivel[p.nivel] || 'color:#6b7280'
    const imagemHtml = p.capa
      ? `<img src="${baseUrl}${p.capa.replace(/^\//, '')}" alt="${p.titulo}" style="width:100%; height:176px; object-fit:cover;" />`
      : `<div style="height:176px; background:#d1fae5; display:flex; align-items:center; justify-content:center; color:#6ee7b7; font-size:0.75rem;">[ imagem ]</div>`

    return `
      <a href="${baseUrl}projetos/${p.slug}" style="background:white; border-radius:12px; overflow:hidden; border:1px solid #f3f4f6; display:block; text-decoration:none; transition:box-shadow 0.2s;"
        onmouseover="this.style.boxShadow='0 10px 25px rgba(0,0,0,0.1)'"
        onmouseout="this.style.boxShadow='none'">
        ${imagemHtml}
        <div style="padding:16px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
            <span style="font-size:0.75rem; font-weight:600; ${corNivel}">● ${p.nivel}</span>
          </div>
          <h3 style="font-weight:700; color:#111827; font-size:0.875rem; line-height:1.4; margin:0 0 4px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${p.titulo}</h3>
          <p style="color:#6b7280; font-size:0.75rem; line-height:1.4; margin:0 0 12px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${p.resumo}</p>
          <div style="display:flex; align-items:center; justify-content:space-between; font-size:0.75rem; color:#9ca3af;">
            <span>👤 ${p.autor}</span>
            <span>⏱ ${p.duracao}</span>
          </div>
        </div>
      </a>
    `
  }

  // ── RENDERIZAR ────────────────────────────────────────
  function renderizar() {
    const filtrados = projetos.filter(p => {
      const okCategoria = filtros.categoria === 'Todos' || p.categoria === filtros.categoria
      const okNivel = filtros.nivel === 'Todos' || p.nivel === filtros.nivel
      const okDuracao = filtros.duracao === 'Todos' || p.duracao === filtros.duracao
      const okIdade = filtros.idade === 'Todos' || p.idade === filtros.idade
      const okBusca = filtros.busca === '' ||
        p.titulo.toLowerCase().includes(filtros.busca.toLowerCase()) ||
        p.resumo.toLowerCase().includes(filtros.busca.toLowerCase()) ||
        p.tags.some(t => t.toLowerCase().includes(filtros.busca.toLowerCase()))
      return okCategoria && okNivel && okDuracao && okIdade && okBusca
    })

    const total = filtrados.length
    const totalPaginas = Math.ceil(total / porPagina)
    if (paginaAtual > totalPaginas) paginaAtual = 1

    const inicio = (paginaAtual - 1) * porPagina
    const fim = inicio + porPagina
    const paginados = filtrados.slice(inicio, fim)

    const grid = document.getElementById('grid-projetos')
    const contagem = document.getElementById('contagem')
    const paginacao = document.getElementById('paginacao')

    grid.innerHTML = paginados.map(criarCard).join('')

    const de = total === 0 ? 0 : inicio + 1
    const ate = Math.min(fim, total)
    contagem.textContent = total === 0
      ? '0 Projetos encontrados'
      : `Mostrando ${de}–${ate} de ${total} projeto${total !== 1 ? 's' : ''}`

    if (totalPaginas <= 1) {
      paginacao.classList.add('hidden')
      return
    }

    paginacao.classList.remove('hidden')

    const numeros = document.getElementById('numeros-pagina')
    numeros.innerHTML = ''

    const paginas = []
    if (totalPaginas <= 7) {
      for (let i = 1; i <= totalPaginas; i++) paginas.push(i)
    } else {
      paginas.push(1)
      if (paginaAtual > 3) paginas.push('...')
      for (let i = Math.max(2, paginaAtual - 1); i <= Math.min(totalPaginas - 1, paginaAtual + 1); i++) {
        paginas.push(i)
      }
      if (paginaAtual < totalPaginas - 2) paginas.push('...')
      paginas.push(totalPaginas)
    }

    paginas.forEach(p => {
      if (p === '...') {
        const span = document.createElement('span')
        span.textContent = '...'
        span.style.cssText = 'padding:0 4px; color:#9ca3af; display:flex; align-items:center;'
        numeros.appendChild(span)
      } else {
        const btn = document.createElement('button')
        btn.textContent = String(p)
        const ativo = p === paginaAtual
        btn.style.cssText = ativo
          ? 'width:36px; height:36px; border-radius:8px; font-size:0.875rem; font-weight:600; background:#166534; color:white; border:none; cursor:pointer;'
          : 'width:36px; height:36px; border-radius:8px; font-size:0.875rem; background:white; color:#374151; border:1px solid #e5e7eb; cursor:pointer;'
        btn.addEventListener('click', () => {
          paginaAtual = p
          renderizar()
          document.getElementById('projetos')?.scrollIntoView({ behavior: 'smooth' })
        })
        numeros.appendChild(btn)
      }
    })

    const btnAnt = document.getElementById('btn-anterior-pag')
    const btnProx = document.getElementById('btn-proximo-pag')

    btnAnt.disabled = paginaAtual === 1
    btnAnt.style.opacity = paginaAtual === 1 ? '0.3' : '1'
    btnProx.disabled = paginaAtual === totalPaginas
    btnProx.style.opacity = paginaAtual === totalPaginas ? '0.3' : '1'

    btnAnt.onclick = () => {
      if (paginaAtual > 1) {
        paginaAtual--
        renderizar()
        document.getElementById('projetos')?.scrollIntoView({ behavior: 'smooth' })
      }
    }
    btnProx.onclick = () => {
      if (paginaAtual < totalPaginas) {
        paginaAtual++
        renderizar()
        document.getElementById('projetos')?.scrollIntoView({ behavior: 'smooth' })
      }
    }
  }

  // ── CHIPS ESTILO ──────────────────────────────────────
  function ativarChip(grupoId, valor) {
    document.querySelectorAll(`#${grupoId} button`).forEach(btn => {
      const ativo = btn.textContent.trim() === valor
      if (ativo) {
        btn.style.cssText = 'background:#166534; color:white; border-color:#166534; padding:4px 16px; border-radius:999px; font-size:0.875rem; font-weight:500; border-width:1px; border-style:solid;'
      } else {
        btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 16px; border-radius:999px; font-size:0.875rem; font-weight:500; border-width:1px; border-style:solid;'
      }
    })
  }

  // ── CATEGORIA ─────────────────────────────────────────
  document.querySelectorAll('#chips-categoria button').forEach(btn => {
    btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:6px 16px; border-radius:999px; font-size:0.875rem; font-weight:500; border-width:1px; border-style:solid;'
    btn.addEventListener('click', () => {
      filtros.categoria = btn.dataset.categoria || 'Todos'
      paginaAtual = 1
      ativarChip('chips-categoria', filtros.categoria)
      renderizar()
    })
  })

  // ── NÍVEL ─────────────────────────────────────────────
  document.querySelectorAll('#chips-nivel button').forEach(btn => {
    btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid;'
    btn.addEventListener('click', () => {
      filtros.nivel = btn.textContent.trim()
      paginaAtual = 1
      ativarChip('chips-nivel', filtros.nivel)
      renderizar()
    })
  })

  // ── DURAÇÃO ───────────────────────────────────────────
  document.querySelectorAll('#chips-duracao button').forEach(btn => {
    btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid;'
    btn.addEventListener('click', () => {
      filtros.duracao = btn.textContent.trim()
      paginaAtual = 1
      ativarChip('chips-duracao', filtros.duracao)
      renderizar()
    })
  })

  // ── IDADE ─────────────────────────────────────────────
  document.querySelectorAll('#chips-idade button').forEach(btn => {
    btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid;'
    btn.addEventListener('click', () => {
      filtros.idade = btn.textContent.trim()
      paginaAtual = 1
      ativarChip('chips-idade', filtros.idade)
      renderizar()
    })
  })

  // ── BUSCA ─────────────────────────────────────────────
  document.getElementById('busca')?.addEventListener('input', (e) => {
    filtros.busca = e.target.value
    paginaAtual = 1
    renderizar()
  })

  // ── TOGGLE FILTROS ────────────────────────────────────
  document.getElementById('btn-filtros')?.addEventListener('click', () => {
    document.getElementById('filtros-expandidos')?.classList.toggle('hidden')
  })

  // ── POR PÁGINA ────────────────────────────────────────
  document.querySelectorAll('.chip-por-pagina').forEach(btn => {
    btn.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid; cursor:pointer;'
    btn.addEventListener('click', () => {
      porPagina = parseInt(btn.dataset.n || '6')
      paginaAtual = 1
      document.querySelectorAll('.chip-por-pagina').forEach(b => {
        b.style.cssText = 'background:white; color:#4b5563; border-color:#e5e7eb; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid; cursor:pointer;'
      })
      btn.style.cssText = 'background:#166534; color:white; border-color:#166534; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid; cursor:pointer;'
      renderizar()
    })
  })

 // ── INIT ──────────────────────────────────────────────
ativarChip('chips-categoria', 'Todos')
ativarChip('chips-nivel', 'Todos')
ativarChip('chips-duracao', 'Todos')
ativarChip('chips-idade', 'Todos')

document.querySelector('.chip-por-pagina[data-n="6"]')?.setAttribute(
  'style',
  'background:#166534; color:white; border-color:#166534; padding:4px 12px; border-radius:999px; font-size:0.875rem; border-width:1px; border-style:solid; cursor:pointer;'
)

renderizar()

// ── HERO VIDEO ───────────────────────────────────────
const heroVideos = [
  `${baseUrl}videos/video1.mp4`,
  `${baseUrl}videos/video2.mp4`,
  `${baseUrl}videos/video3.mp4`,
  `${baseUrl}videos/video4.mp4`,
  `${baseUrl}videos/video5.mp4`,
]

const videoA = document.getElementById("hero-video-a")
const videoB = document.getElementById("hero-video-b")

let videoAtualIndex = 1
let mostrandoA = true

function prepararVideo(video, src) {
  if (!video) return

  video.pause()
  video.src = src
  video.load()

  video.onloadeddata = () => {
    video.currentTime = 0
    video.play().catch(() => {})
  }
}

function trocarHeroVideosComFade() {
  if (!videoA || !videoB) return

  const videoVisivel = mostrandoA ? videoA : videoB
  const videoOculto = mostrandoA ? videoB : videoA

  videoAtualIndex = (videoAtualIndex + 1) % heroVideos.length
  const proximoSrc = heroVideos[videoAtualIndex]

  prepararVideo(videoOculto, proximoSrc)

  setTimeout(() => {
    videoOculto.classList.remove("opacity-0")
    videoOculto.classList.add("opacity-80")

    videoVisivel.classList.remove("opacity-80")
    videoVisivel.classList.add("opacity-0")

    mostrandoA = !mostrandoA
  }, 300)
}

setInterval(trocarHeroVideosComFade, 9000)

</script>