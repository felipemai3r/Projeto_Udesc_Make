---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "UDESC Maker" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | UDESC Maker</title>
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <header
      class="flex items-center justify-between px-8 py-4 border-b border-gray-100"
    >
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="text-xl font-bold text-green-800">UDESC Maker</a
      >
      <nav class="flex items-center gap-6">
        <a
          href={`${import.meta.env.BASE_URL}`}
          class="text-gray-700 hover:text-green-800 transition-colors"
          >Projetos</a
        >
        <a
          href={`${import.meta.env.BASE_URL}contribuir`}
          class="text-gray-700 hover:text-green-800 transition-colors"
          >Como Contribuir</a
        >
        <a
          href={`${import.meta.env.BASE_URL}enviar`}
          class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg transition-colors font-medium"
        >
          Enviar Projeto
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-green-50 py-8 text-center mt-16">
      <p class="text-green-800 font-bold text-sm">UDESC MAKER</p>
      <p class="text-green-700 text-sm">
        Plataforma colaborativa de projetos maker da UDESC
      </p>
      <p class="text-gray-500 text-xs mt-3">
        © 2026 UDESC Maker. Todos os direitos reservados.
      </p>
    </footer>
  </body>
</html>
